{
  "name": "bh-gallery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "seed": "tsx --env-file=.env.local scripts/seed-firestore.ts",
    "firebase:emulators": "npx -y firebase-tools@latest emulators:start",
    "firebase:deploy:rules": "npx -y firebase-tools@latest deploy --only firestore:rules,storage",
    "firebase:deploy:indexes": "npx -y firebase-tools@latest deploy --only firestore:indexes"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.14.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
